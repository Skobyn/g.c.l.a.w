# Firebase client config — required for real Google Sign-In.
# Leave these blank when using NEXT_PUBLIC_DEV_BYPASS_AUTH=true.
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Backend URL. Use http://localhost:8000 for a local backend, or the
# deployed Cloud Run URL to point at prod:
#   https://gclaw-982188522148.us-central1.run.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# When "true", skip Firebase entirely: the AuthProvider returns a
# stub user and getIdToken returns "dev-user". The backend's
# DevUserMiddleware (FIREBASE_AUTH_ENABLED=false) ignores the
# Authorization header anyway. Use this for local frontend dev
# against a dev-mode backend. NEVER set this against a prod backend
# that has FIREBASE_AUTH_ENABLED=true.
NEXT_PUBLIC_DEV_BYPASS_AUTH=false
